rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Photos d'état des lieux des missions
    match /missions/{missionId}/{allPaths=**} {
      allow read: if request.auth != null && 
        (firestore.get(/databases/(default)/documents/missions/$(missionId)).data.convoyeurId == request.auth.uid ||
         firestore.get(/databases/(default)/documents/missions/$(missionId)).data.clientId == request.auth.uid ||
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
      
      allow write: if request.auth != null && 
        (firestore.get(/databases/(default)/documents/missions/$(missionId)).data.convoyeurId == request.auth.uid ||
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    // Documents des utilisateurs (permis, assurance, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Ressources publiques (logos, images génériques)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Documents administratifs (factures, contrats)
    match /admin/{allPaths=**} {
      allow read: if request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow write: if request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Par défaut : aucun accès
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
